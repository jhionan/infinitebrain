# ─── Application ──────────────────────────────────────────────────────────────
APP_NAME=infinite-brain
APP_ENV=local          # local | staging | production
APP_VERSION=dev
LOG_LEVEL=debug        # debug | info | warn | error

# ─── Server ───────────────────────────────────────────────────────────────────
PORT=8080
SERVER_READ_TIMEOUT=15s
SERVER_WRITE_TIMEOUT=15s
SERVER_IDLE_TIMEOUT=60s

# ─── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgres://infinitebrain:infinitebrain@localhost:5432/infinitebrain?sslmode=disable
DB_MAX_OPEN_CONNS=25
DB_MAX_IDLE_CONNS=5
DB_CONN_MAX_LIFETIME=5m

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=
REDIS_DB=0

# ─── Auth ─────────────────────────────────────────────────────────────────────
# IMPORTANT: Replace with a strong random secret (min 32 chars) in non-local envs
JWT_SECRET=change-me-to-a-strong-random-secret-at-least-32-chars
JWT_ACCESS_DURATION=15m
JWT_REFRESH_DURATION=168h  # 7 days

# ─── AI Providers ─────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...         # Used for Whisper transcription and embeddings
AI_DEFAULT_PROVIDER=anthropic # anthropic | openai

# ─── Storage (S3-compatible) ──────────────────────────────────────────────────
S3_BUCKET=infinitebrain
S3_ENDPOINT=http://localhost:9000   # MinIO for local dev; AWS S3 endpoint for prod
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_REGION=us-east-1
S3_USE_SSL=false                    # true in production

# ─── Push Notifications ───────────────────────────────────────────────────────
APNS_KEY_ID=
APNS_TEAM_ID=
APNS_BUNDLE_ID=io.infinitebrain.app
APNS_KEY_PATH=./configs/apns_key.p8

# ─── Integrations ─────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
WHATSAPP_API_KEY=
WHATSAPP_PHONE_NUMBER_ID=
SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# ─── Observability ────────────────────────────────────────────────────────────
OTEL_ENDPOINT=http://localhost:4318  # OTLP HTTP endpoint
OTEL_SERVICE_NAME=infinite-brain
